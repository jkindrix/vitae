{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/jkindrix/vitae/schemas/resume.schema.json",
  "title": "Vitae Resume Schema",
  "description": "Schema for vitae resume YAML files",
  "type": "object",
  "required": ["meta", "experience"],
  "additionalProperties": false,
  "definitions": {
    "highlight": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "description": "Highlight text"
            },
            "tags": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Tags for variant filtering"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for variant filtering"
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "description": "Personal and contact information",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Full name"
        },
        "title": {
          "type": "string",
          "description": "Professional title or tagline"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "location": {
          "type": "string",
          "description": "City, State or City, Country"
        },
        "links": {
          "type": "array",
          "description": "Professional links (LinkedIn, GitHub, portfolio, etc.)",
          "items": {
            "type": "object",
            "required": ["url"],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "description": "Display text for the link"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "URL"
              }
            }
          }
        }
      }
    },
    "language": {
      "type": "string",
      "description": "Locale code for section headings and date formatting (e.g., 'en', 'fr', 'es', 'de', 'pt'). When omitted, defaults to English.",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "summary": {
      "type": "string",
      "description": "Professional summary or objective"
    },
    "skills": {
      "type": "array",
      "description": "Categorized skills",
      "items": {
        "type": "object",
        "required": ["category", "items"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for variant pick selection"
          },
          "category": {
            "type": "string",
            "description": "Skill category name"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of skills in this category"
          },
          "tags": { "$ref": "#/definitions/tags" }
        }
      }
    },
    "experience": {
      "type": "array",
      "description": "Work experience",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["company", "roles"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for variant pick selection"
          },
          "company": {
            "type": "string",
            "description": "Company or organization name"
          },
          "tags": { "$ref": "#/definitions/tags" },
          "roles": {
            "type": "array",
            "description": "Roles held at this company (supports multiple roles at same company)",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title", "start"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Stable identifier for variant pick selection"
                },
                "title": {
                  "type": "string",
                  "description": "Job title"
                },
                "start": {
                  "type": "string",
                  "description": "Start date (YYYY-MM or YYYY)",
                  "pattern": "^\\d{4}(-\\d{2})?$"
                },
                "end": {
                  "type": "string",
                  "description": "End date (YYYY-MM, YYYY, or 'present')",
                  "pattern": "^(\\d{4}(-\\d{2})?|present|Present)$"
                },
                "location": {
                  "type": "string",
                  "description": "Work location"
                },
                "summary": {
                  "type": "string",
                  "description": "Brief summary of the role before listing highlights"
                },
                "highlights": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/highlight" },
                  "description": "Key accomplishments and responsibilities"
                },
                "tags": { "$ref": "#/definitions/tags" }
              }
            }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "description": "Notable projects or open source work",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for variant pick selection"
          },
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Project URL"
          },
          "description": {
            "type": "string",
            "description": "Brief project description"
          },
          "highlights": {
            "type": "array",
            "items": { "$ref": "#/definitions/highlight" },
            "description": "Key features or accomplishments"
          },
          "tags": { "$ref": "#/definitions/tags" }
        }
      }
    },
    "education": {
      "type": "array",
      "description": "Educational background",
      "items": {
        "type": "object",
        "required": ["institution"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for variant pick selection"
          },
          "institution": {
            "type": "string",
            "description": "School or institution name"
          },
          "degree": {
            "type": "string",
            "description": "Degree or certification earned"
          },
          "field": {
            "type": "string",
            "description": "Field of study"
          },
          "start": {
            "type": "string",
            "description": "Start year"
          },
          "end": {
            "type": "string",
            "description": "End year or 'present'"
          },
          "highlights": {
            "type": "array",
            "items": { "$ref": "#/definitions/highlight" },
            "description": "Notable achievements"
          },
          "tags": { "$ref": "#/definitions/tags" }
        }
      }
    },
    "certifications": {
      "type": "array",
      "description": "Professional certifications",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for variant pick selection"
          },
          "name": {
            "type": "string",
            "description": "Certification name"
          },
          "issuer": {
            "type": "string",
            "description": "Issuing organization"
          },
          "date": {
            "type": "string",
            "description": "Date earned"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Verification URL"
          },
          "tags": { "$ref": "#/definitions/tags" }
        }
      }
    },
    "languages": {
      "type": "array",
      "description": "Languages spoken",
      "items": {
        "type": "object",
        "required": ["language"],
        "additionalProperties": false,
        "properties": {
          "language": {
            "type": "string",
            "description": "Language name"
          },
          "fluency": {
            "type": "string",
            "description": "Fluency level (e.g., Native, Fluent, Professional, Conversational)"
          }
        }
      }
    },
    "awards": {
      "type": "array",
      "description": "Awards and honors",
      "items": {
        "type": "object",
        "required": ["title"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "description": "Award title"
          },
          "awarder": {
            "type": "string",
            "description": "Organization that gave the award"
          },
          "date": {
            "type": "string",
            "description": "Date received"
          },
          "summary": {
            "type": "string",
            "description": "Brief description of the award"
          }
        }
      }
    },
    "publications": {
      "type": "array",
      "description": "Academic or professional publications",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Publication title"
          },
          "publisher": {
            "type": "string",
            "description": "Publisher or journal name"
          },
          "releaseDate": {
            "type": "string",
            "description": "Publication date"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the publication"
          },
          "summary": {
            "type": "string",
            "description": "Brief description or abstract"
          }
        }
      }
    },
    "volunteer": {
      "type": "array",
      "description": "Volunteer experience",
      "items": {
        "type": "object",
        "required": ["organization"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable identifier for variant pick selection"
          },
          "organization": {
            "type": "string",
            "description": "Organization name"
          },
          "position": {
            "type": "string",
            "description": "Role or position"
          },
          "start": {
            "type": "string",
            "description": "Start date"
          },
          "end": {
            "type": "string",
            "description": "End date"
          },
          "summary": {
            "type": "string",
            "description": "Brief description of the work"
          },
          "highlights": {
            "type": "array",
            "items": { "$ref": "#/definitions/highlight" },
            "description": "Key accomplishments"
          },
          "tags": { "$ref": "#/definitions/tags" }
        }
      }
    },
    "references": {
      "type": "array",
      "description": "Professional references",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Reference name"
          },
          "reference": {
            "type": "string",
            "description": "Reference quote or testimonial"
          }
        }
      }
    },
    "theme": {
      "type": "object",
      "description": "Theme customization overrides for colors and fonts",
      "additionalProperties": false,
      "properties": {
        "colors": {
          "type": "object",
          "description": "Color overrides (CSS custom property values)",
          "additionalProperties": false,
          "properties": {
            "accent": {
              "type": "string",
              "description": "Primary accent color (e.g., '#2563eb')"
            },
            "text": {
              "type": "string",
              "description": "Main text color"
            },
            "textSecondary": {
              "type": "string",
              "description": "Secondary text color"
            },
            "textMuted": {
              "type": "string",
              "description": "Muted/subtle text color"
            },
            "background": {
              "type": "string",
              "description": "Page background color"
            },
            "border": {
              "type": "string",
              "description": "Border/divider color"
            }
          }
        },
        "fonts": {
          "type": "object",
          "description": "Font family overrides",
          "additionalProperties": false,
          "properties": {
            "sans": {
              "type": "string",
              "description": "Sans-serif font stack (e.g., 'Inter, sans-serif')"
            },
            "serif": {
              "type": "string",
              "description": "Serif font stack (e.g., 'Merriweather, serif')"
            }
          }
        }
      }
    }
  }
}
